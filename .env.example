# Database
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
# DIRECT_URL should point to the direct Postgres connection used for migrations.
# Use this if your runtime DATABASE_URL is pooled (for example via Supabase or pgbouncer).
DIRECT_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# If using NextAuth v5 or AUTH_URL instead of NEXTAUTH_URL:
# AUTH_URL=https://your-vercel-domain.vercel.app
# AUTH_SECRET=your-nextauth-secret
